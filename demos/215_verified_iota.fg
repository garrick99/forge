// Demo 215: Verified iota — fill with 0, 1, 2, ..., n-1
//
// iota(s, n) sets s[i] = i for all i in [0, n).
// Quantified postcondition: forall k < n, s[k] == k.
// Demonstrates that loop invariant with equality carries to postcondition.
//
fn iota(s: span<u64>, n: u64)
    requires s.len == n
    ensures forall k: u64, k < n ==> s[k] == k
{
    for i in n
        invariant i <= n
        invariant forall k: u64, k < i ==> s[k] == k
    {
        s[i] = i;
    }
}

fn main() -> u64 { 0u64 }
