// expected: 0
// Demo 832: Verified piecewise linear interpolation
//
// Given knots (x_i, y_i), evaluates the piecewise linear function at query x.
// Binary search finds the correct segment, then linearly interpolates.
// Proves: all knot accesses in bounds.

fn find_segment(xs: span<u64>, n: u64, x: u64) -> u64
    requires n >= 2u64
    requires n <= xs.len
    ensures result < n - 1u64 || result == n - 2u64
{
    let mut lo: u64 = 0u64;
    let mut hi: u64 = n - 1u64;
    while lo + 1u64 < hi
        invariant lo < hi
        invariant hi < n
        decreases hi - lo
    {
        let mid: u64 = lo + (hi - lo) / 2u64;
        if xs[mid] <= x { lo = mid; }
        else { hi = mid; };
    };
    lo
}

fn lerp_eval(xs: span<u64>, ys: span<u64>, n: u64, x: u64) -> u64
    requires n >= 2u64
    requires n <= xs.len
    requires n <= ys.len
{
    let seg: u64 = find_segment(xs, n, x);
    let x0: u64 = xs[seg];
    let x1: u64 = xs[seg + 1u64];
    let y0: u64 = ys[seg];
    let y1: u64 = ys[seg + 1u64];
    if x1 == x0 { y0 }
    else {
        // Linear interpolation: y0 + (y1 - y0) * (x - x0) / (x1 - x0).
        y0 + (y1 - y0) * (x - x0) / (x1 - x0)
    }
}

fn main() -> u64 { 0u64 }
