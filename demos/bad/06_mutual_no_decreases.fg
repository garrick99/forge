// BAD Demo 06: mutual recursion without decreases: clause
//
// is_even and is_odd are mutually recursive.
// is_odd is missing its decreases: clause.
// FORGE should reject this with a type error.

fn is_even(n: u64) -> bool
  decreases n
{
  if n == 0 { true } else { is_odd(n - 1) }
}

// Missing 'decreases n' here — FORGE detects the SCC and flags this.
fn is_odd(n: u64) -> bool
{
  if n == 0 { false } else { is_even(n - 1) }
}
