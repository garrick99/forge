.version 9.0
.target sm_120
.address_size 64

.visible .entry vec_memory_mix3(
    .param .u64 a, .param .u64 a_len, .param .u64 b, .param .u64 b_len, .param .u64 c, .param .u64 c_len, .param .u32 n)
{
    .reg .b32 %r<4>;
    .reg .b64 %rd<6>;
    .reg .pred %p<1>;

    ld.param.u64 %rd0, [a];
    ld.param.u64 %rd1, [a_len];
    ld.param.u64 %rd1, [b];
    ld.param.u64 %rd2, [b_len];
    ld.param.u64 %rd2, [c];
    ld.param.u64 %rd3, [c_len];
    ld.param.u32 %r0, [n];
    mov.u32 %r1, %ctaid.x;
    mov.u32 %r2, %ntid.x;
    mul.lo.u32 %r3, %r1, %r2;
    mov.u32 %r1, %tid.x;
    add.u32 %r2, %r3, %r1;
    add.u32 %r3, %r2, 5;
    add.u32 %r1, %r0, 5;
    setp.lt.u32 %p0, %r3, %r1;
    @!%p0 ret;
    shl.b32 %r0, %r2, 2;
    cvt.u64.u32 %rd4, %r0;
    add.u64 %rd3, %rd0, %rd4;
    ld.global.u32 %r1, [%rd3];
    shl.b32 %r2, %r3, 2;
    cvt.u64.u32 %rd5, %r2;
    add.u64 %rd0, %rd1, %rd5;
    ld.global.u32 %r3, [%rd0];
    add.u64 %rd1, %rd2, %rd4;
    ld.global.u32 %r2, [%rd1];
    shl.b32 %r0, %r1, 1;
    add.u32 %r1, %r0, %r3;
    xor.b32 %r3, %r1, %r2;
    st.global.u32 [%rd3], %r3;
    bra if_merge_4;
if_merge_4:
    ret;
}
