.version 9.0
.target sm_120
.address_size 64

.visible .entry vec_shfl_pair(
    .param .u64 a, .param .u64 a_len, .param .u64 out, .param .u64 out_len, .param .u32 n)
{
    .reg .b32 %r<6>;
    .reg .b64 %rd<4>;
    .reg .pred %p<1>;

    ld.param.u64 %rd0, [a];
    ld.param.u64 %rd1, [a_len];
    ld.param.u64 %rd1, [out];
    ld.param.u64 %rd2, [out_len];
    ld.param.u32 %r0, [n];
    mov.u32 %r1, %tid.x;
    setp.lt.u32 %p0, %r1, %r0;
    @!%p0 ret;
    shl.b32 %r2, %r1, 2;
    cvt.u64.u32 %rd3, %r2;
    add.u64 %rd0, %rd0, %rd3;
    ld.global.u32 %r3, [%rd0];
    shfl.sync.bfly.b32 %r4, %r3, 1, 31, 4294967295;
    add.u64 %rd1, %rd1, %rd3;
    add.u32 %r5, %r3, %r4;
    st.global.u32 [%rd1], %r5;
    bra if_merge_4;
if_merge_4:
    ret;
}
