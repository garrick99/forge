.version 9.0
.target sm_120
.address_size 64

.visible .entry vec_2d_add(
    .param .u64 a, .param .u64 a_len, .param .u64 b, .param .u64 b_len, .param .u64 out, .param .u64 out_len, .param .u32 n, .param .u32 width)
{
    .reg .b32 %r<10>;
    .reg .b64 %rd<5>;
    .reg .pred %p<1>;

    ld.param.u64 %rd0, [a];
    ld.param.u64 %rd1, [a_len];
    ld.param.u64 %rd1, [b];
    ld.param.u64 %rd2, [b_len];
    ld.param.u64 %rd2, [out];
    ld.param.u64 %rd3, [out_len];
    ld.param.u32 %r0, [n];
    ld.param.u32 %r1, [width];
    mov.u32 %r2, %tid.x;
    mov.u32 %r3, %ctaid.x;
    mul.lo.u32 %r4, %r3, %r1;
    add.u32 %r5, %r4, %r2;
    setp.lt.u32 %p0, %r5, %r0;
    @!%p0 ret;
    shl.b32 %r6, %r5, 2;
    cvt.u64.u32 %rd4, %r6;
    add.u64 %rd0, %rd0, %rd4;
    ld.global.u32 %r7, [%rd0];
    add.u64 %rd1, %rd1, %rd4;
    ld.global.u32 %r8, [%rd1];
    add.u64 %rd2, %rd2, %rd4;
    add.u32 %r9, %r7, %r8;
    st.global.u32 [%rd2], %r9;
    bra if_merge_4;
if_merge_4:
    ret;
}
