// FORGE-generated PTX — SM_120
// Proofs discharged before emission. Correct by construction.

.version 8.8
.target sm_120
.address_size 64

.visible .entry devfn_trigger(
    .param .u64 devfn_trigger_param_output_data,
    .param .u64 devfn_trigger_param_output_len,
    .param .u64 devfn_trigger_param_n
)
{
