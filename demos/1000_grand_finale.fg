// --- 1. Modular exponentiation (crypto primitive) ---
fn mod_exp(base: u64, exp: u64, p: u64) -> u64
    requires p > 1u64
    requires base < p
    ensures result < p
{
    let mut b: u64 = base;
    let mut e: u64 = exp;
    let mut acc: u64 = 1u64;
    while e > 0u64
        invariant acc < p
        invariant b < p
        decreases e
    {
        if e % 2u64 == 1u64 {
            acc = (acc * b) % p;
        };
        b = (b * b) % p;
        e = e / 2u64;
    };
    acc
}

// --- 2. Recursive structure: Fibonacci with inductive bound ---
fn fib_bounded(n: u64) -> u64
    requires n <= 40u64
    decreases n
{
    if n == 0u64 { 0u64 }
    else if n == 1u64 { 1u64 }
    else {
        let a: u64 = fib_bounded(n - 1u64);
        let b: u64 = fib_bounded(n - 2u64);
        a + b
    }
}

// --- 3. Quantified postcondition: verified fill ---
fn verified_fill(s: span<u64>, n: u64, val: u64)
    requires s.len == n
    ensures forall k: u64, k < n ==> s[k] == val
{
    let mut i: u64 = 0u64;
    while i < n
        invariant i <= n
        invariant forall k: u64, k < i ==> s[k] == val
        decreases n - i
    {
        s[i] = val;
        i = i + 1u64;
    };
}

// --- 4. Cross-function composition: hash then verify ---
fn compute_hash(data: span<u64>, n: u64, p: u64) -> u64
    requires data.len == n
    requires p > 1u64
    ensures result < p
{
    let mut h: u64 = 0u64;
    let mut i: u64 = 0u64;
    while i < n
        invariant i <= n
        invariant h < p
        decreases n - i
    {
        h = (h * 31u64 + data[i]) % p;
        i = i + 1u64;
    };
    h
}

fn verify_hash(data: span<u64>, n: u64, p: u64, expected: u64) -> bool
    requires data.len == n
    requires p > 1u64
    requires expected < p
{
    let h: u64 = compute_hash(data, n, p);
    h == expected
}

// --- 5. Graph algorithm: BFS layer computation ---
fn bfs_layer(adj: span<u64>, n: u64, visited: span<u64>, queue: span<u64>, qlen: u64, next_q: span<u64>) -> u64
    requires adj.len == n * n
    requires visited.len == n
    requires queue.len == qlen
    requires next_q.len == n
    requires n > 0u64
    ensures result <= n
{
    let mut nq: u64 = 0u64;
    let mut qi: u64 = 0u64;
    while qi < qlen
        invariant qi <= qlen
        invariant nq <= n
        decreases qlen - qi
    {
        let u: u64 = queue[qi];
        if u < n {
            let mut v: u64 = 0u64;
            while v < n
                invariant v <= n
                invariant nq <= n
                decreases n - v
            {
                let idx: u64 = u * n + v;
                if idx < n * n {
                    if adj[idx] > 0u64 {
                        if visited[v] == 0u64 {
                            visited[v] = 1u64;
                            if nq < n {
                                next_q[nq] = v;
                                nq = nq + 1u64;
                            };
                        };
                    };
                };
                v = v + 1u64;
            };
        };
        qi = qi + 1u64;
    };
    nq
}

// --- 6. Dynamic programming: longest increasing subsequence length ---
fn lis_length(seq: span<u64>, dp: span<u64>, n: u64) -> u64
    requires seq.len == n
    requires dp.len == n
    requires n > 0u64
    ensures result >= 1u64
    ensures result <= n
{
    let mut i: u64 = 0u64;
    while i < n
        invariant i <= n
        invariant forall k: u64, k < i ==> dp[k] >= 1u64
        invariant forall k: u64, k < i ==> dp[k] <= n
        decreases n - i
    {
        dp[i] = 1u64;
        let mut j: u64 = 0u64;
        while j < i
            invariant j <= i
            invariant dp[i] >= 1u64
            invariant dp[i] <= n
            decreases i - j
        {
            if seq[j] < seq[i] {
                if dp[j] + 1u64 > dp[i] {
                    if dp[j] + 1u64 <= n {
                        dp[i] = dp[j] + 1u64;
                    };
                };
            };
            j = j + 1u64;
        };
        i = i + 1u64;
    };
    // Find max
    let mut best: u64 = dp[0u64];
    let mut k: u64 = 1u64;
    while k < n
        invariant k <= n
        invariant best >= 1u64
        invariant best <= n
        decreases n - k
    {
        if dp[k] > best { best = dp[k]; };
        k = k + 1u64;
    };
    best
}

// --- 7. Verified data structure: priority queue extract-min ---
fn pq_extract_min(heap: span<u64>, n: u64) -> (u64, u64)
    requires heap.len == n
    requires n > 0u64
    ensures result.1 == n - 1u64
{
    let min_val: u64 = heap[0u64];
    // Move last to root, sift down
    heap[0u64] = heap[n - 1u64];
    let new_n: u64 = n - 1u64;
    let mut pos: u64 = 0u64;
    let mut steps: u64 = 0u64;
    while steps < new_n
        invariant pos < n
        invariant steps <= new_n
        decreases new_n - steps
    {
        let left: u64 = 2u64 * pos + 1u64;
        let right: u64 = 2u64 * pos + 2u64;
        let mut smallest: u64 = pos;
        if left < new_n {
            if heap[left] < heap[smallest] {
                smallest = left;
            };
        };
        if right < new_n {
            if heap[right] < heap[smallest] {
                smallest = right;
            };
        };
        if smallest == pos {
            steps = new_n;  // exit
        } else {
            let tmp: u64 = heap[pos];
            heap[pos] = heap[smallest];
            heap[smallest] = tmp;
            pos = smallest;
            steps = steps + 1u64;
        };
    };
    (min_val, new_n)
}

// --- 8. Ghost accumulator: bounded sum with ghost witness ---
fn ghost_bounded_sum(s: span<u64>, n: u64, cap: u64) -> u64
    requires s.len == n
    requires forall k: u64, k < n ==> s[k] <= cap
    ensures result <= n * cap
{
    ghost let bound: u64 = n * cap;
    let mut acc: u64 = 0u64;
    let mut i: u64 = 0u64;
    while i < n
        invariant i <= n
        invariant acc <= i * cap
        decreases n - i
    {
        acc = acc + s[i];
        i = i + 1u64;
    };
    acc
}

