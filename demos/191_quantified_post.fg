// Demo 191: Quantified array postcondition
//
// After zeroing a span, prove that ALL elements are zero.
// This requires a universally quantified postcondition:
//   ensures forall k, k < n ==> s[k] == 0
//
fn zero_span(s: span<u64>, n: u64)
    requires s.len == n
    ensures forall k: u64, k < n ==> s[k] == 0u64
{
    for i in n
        invariant i <= n
        invariant forall k: u64, k < i ==> s[k] == 0u64
    {
        s[i] = 0u64;
    }
}

fn main() -> u64 { 0u64 }
