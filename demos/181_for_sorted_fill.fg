// expected: 0
// Demo 181: For-loop with invariant — fill array with ascending values
//
// Demonstrates for-loop invariant checking.
// Each element s[i] is set to i*2; invariant: all filled elements are even.
// The invariant is maintained at entry and after each iteration.
//
fn fill_even(s: span<u64>)
    requires s.len == 8u64
{
    for i in 8u64
        invariant i <= 8u64
    {
        s[i] = i * 2u64;
    }
}

fn main() -> u64 { 0u64 }
