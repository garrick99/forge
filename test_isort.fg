// Insertion sort: cleaner invariants
// Key insight: the inner loop maintains forall a < b < k, s[a] <= s[b]
// (outer sorted inv is preserved by duplicate-writes: s[j] = s[j-1] only
//  copies value, keeping the sorted order intact up to position k-1).
// The extended invariant forall a<b<=k && a>j tracks the shifted region.
fn insertion_sort(s: span<u64>)
    requires s.len <= 50u64
    ensures forall a: u64, forall b: u64, a < b && b < s.len ==> s[a] <= s[b]
{
    let n: u64 = s.len;
    let mut k: u64 = 0u64;
    while k < n
        invariant k <= n
        invariant forall a: u64, forall b: u64, a < b && b < k ==> s[a] <= s[b]
        decreases n - k
    {
        let key: u64 = s[k];
        let mut j: u64 = k;
        while j > 0u64 && s[j - 1u64] > key
            invariant j <= k
            invariant forall a: u64, forall b: u64, a < b && b < k ==> s[a] <= s[b]
            invariant forall a: u64, forall b: u64,
                        a < b && b <= k && a > j ==> s[a] <= s[b]
            invariant forall a: u64, a > j && a <= k ==> s[a] > key
            decreases j
        {
            s[j] = s[j - 1u64];
            j = j - 1u64;
        };
        s[j] = key;
        k = k + 1u64;
    }
}

fn main() -> u64 { 0u64 }
