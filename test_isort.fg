// Minimal test: single postcondition with old()
struct S { size: u64, cap: u64 }

fn s_new(cap: u64) -> S
    requires cap > 0u64
    ensures result.size == 0u64
    ensures result.cap  == cap
{
    struct S { size: 0u64, cap: cap }
}

fn s_push(b: refmut<S>)
    requires (*b).size < (*b).cap
    ensures  (*b).size == old((*b).size) + 1u64
{
    (*b).size = (*b).size + 1u64;
}

fn push_one(cap: u64) -> u64
    requires cap > 1u64
    ensures result == 1u64
{
    let b: S = s_new(cap);
    s_push(&mut b);
    b.size
}
